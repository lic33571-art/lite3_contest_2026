<?xml version="1.0"?>
<launch>
  <!-- 巡线导航模块启动文件 -->
  
  <!-- 加载参数 -->
  <rosparam file="$(find line_tracking)/../config/contest_params.yaml" command="load" ns="line_tracking"/>
  
  <!-- 启动巡线节点 -->
  <node pkg="line_tracking" type="line_tracker.py" name="line_tracker" output="screen">
    <!-- ROI参数 -->
    <param name="roi_top" value="0.50"/>
    <param name="roi_bottom" value="0.95"/>
    
    <!-- 速度参数 -->
    <param name="linear_x" value="0.10"/>
    <param name="linear_x_min" value="0.06"/>
    
    <!-- PD控制器 -->
    <param name="kp_track" value="0.004"/>
    <param name="kd_track" value="0.003"/>
    <param name="dead_zone" value="20"/>
    <param name="history_size" value="5"/>
    <param name="cluster_max_gap" value="100"/>
    
    <!-- 避障参数 -->
    <param name="black_safe_distance" value="120"/>
    <param name="black_danger_distance" value="80"/>
    <param name="black_warn_distance" value="45"/>
    <param name="avoid_kp" value="0.008"/>
    <param name="avoid_weight" value="2.5"/>
    <param name="avoid_max" value="0.40"/>
    
    <!-- LOST扫描 -->
    <param name="scan_angular" value="0.20"/>
    <param name="scan_period" value="40"/>
    <param name="scan_speed" value="0.04"/>
    
    <!-- 冲出保护 -->
    <param name="outbound_recover_angular" value="0.25"/>
    
    <!-- 白线检测 -->
    <param name="white_line_min_area" value="40"/>
    <param name="white_line_aspect_min" value="1.0"/>
    <param name="white_line_aspect_max" value="50.0"/>
    
    <!-- 锥形桶避障 -->
    <param name="cone_detect_enabled" value="true"/>
    <param name="cone_min_area" value="500"/>
    <param name="cone_avoid_distance" value="150"/>
    <param name="cone_avoid_angular" value="0.3"/>
    
    <!-- 调试图像 -->
    <param name="debug_viz" value="true"/>
  </node>
</launch>
